      "nodes": { "localhost": { "display": [ "disp_forward", "disp_left", "disp_right", "disp_up" ] } },

      "displays": {
        "disp_forward": { "type": "offaxis", "ul": [-1.0, 1.0, 2.0 ], "ll": [-1.0, -1.0, 2.0 ], "lr": [ 1.0, -1.0, 2.0 ], "viewport": "vp_forward" },
        "disp_left": { "type": "offaxis", "ul": [-1.0, 1.0, 0.0 ], "ll": [-1.0, -1.0, 0.0 ], "lr": [-1.0, -1.0, 2.0 ], "viewport": "vp_left" },
        "disp_right": { "type": "offaxis", "ul": [ 1.0, 1.0, 2.0 ], "ll": [ 1.0, -1.0, 2.0 ], "lr": [ 1.0, -1.0, 0.0 ], "viewport": "vp_right" },
        "disp_up": { "type": "offaxis", "ul": [-1.0, 1.0, 0.0 ], "ll": [-1.0, 1.0, 2.0 ], "lr": [ 1.0, 1.0, 2.0 ], "viewport": "vp_up" }
